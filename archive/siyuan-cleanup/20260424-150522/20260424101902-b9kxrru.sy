e","updated":"20260424101902"},"Children":[{"ID":"20260424101902-8i26etz","Type":"NodeParagraph","Properties":{"id":"20260424101902-8i26etz","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"软件栈如何把不同单元组合起来"}]}]},{"ID":"20260424101902-ppqdh5g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-ppqdh5g","updated":"20260424101902"},"Children":[{"ID":"20260424101902-jjb5z2l","Type":"NodeParagraph","Properties":{"id":"20260424101902-jjb5z2l","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"在移动端能效和体验之间做折中"}]}]}]},{"ID":"20260424101902-82p4fql","Type":"NodeParagraph","Properties":{"id":"20260424101902-82p4fql","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"这类平台的典型取舍是："}]},{"ID":"20260424101902-pwa2fbb","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-pwa2fbb","updated":"20260424101902"},"Children":[{"ID":"20260424101902-6t6pfwj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-6t6pfwj","updated":"20260424101902"},"Children":[{"ID":"20260424101902-2zc25f6","Type":"NodeParagraph","Properties":{"id":"20260424101902-2zc25f6","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"不是所有任务都硬塞给 NPU"}]}]},{"ID":"20260424101902-p3ga2hz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-p3ga2hz","updated":"20260424101902"},"Children":[{"ID":"20260424101902-pcbpdzi","Type":"NodeParagraph","Properties":{"id":"20260424101902-pcbpdzi","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"而是让 DSP、向量单元、张量单元按各自擅长的粒度配合"}]}]}]},{"ID":"20260424101902-16sij92","Type":"NodeParagraph","Properties":{"id":"20260424101902-16sij92","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"所以它们代表的不是“纯 NPU 中心主义”，而是："}]},{"ID":"20260424101902-zjxbmsp","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-zjxbmsp","updated":"202604241