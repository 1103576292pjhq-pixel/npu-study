degen；把候选子图标注、切分后交给外部 backend codegen，并把返回的 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"runtime.Module"},{"Type":"NodeText","Data":"​ 接回主执行图。"}]}]},{"ID":"20260424101903-oz5z7pc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101903-oz5z7pc","updated":"20260424101903"},"Children":[{"ID":"20260424101903-sug62w7","Type":"NodeParagraph","Properties":{"id":"20260424101903-sug62w7","updated":"20260424101903"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Target Translation"},{"Type":"NodeText","Data":"​：把低层 IR 分别翻译成 host 侧和 device 侧目标模块的阶段，是编译链进入具体硬件承诺的位置。"}]}]},{"ID":"20260424101903-yqo3de5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101903-yqo3de5","updated":"20260424101903"},"Children":[{"ID":"20260424101903-chhfnit","Type":"NodeParagraph","Properties":{"id":"20260424101903-chhfnit","updated":"20260424101903"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Lowering"},{"Type":"NodeText","Data":"​：把高层图或循环表示逐层压低到更接近目标硬件执行形式的过程。"}]}]},{"ID":"20260424101903-yjrxe6v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101903-yjrxe6v","updated":"20260424101903"},"Children":[{"ID":"20260424101903-yecshdj","Type":"NodeParagraph","Properties":{"id":"20260424101903-yecshdj","updated":"20260424101903"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Codegen"},{"Type":"NodeText","Data":"​：根据 lowering 后的表示生成目标指令、命令流、描述符或 runtime 工件的过程。"}]}]},{"ID":"20260424101903-1ml8cw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101903-1ml8cw9","updated":"20260424101903"},"Children":[{"ID":"20260424101903-yozrj96","Type":"NodeParagraph","Properties":{"id":"20260424101903-yozrj96","updated":