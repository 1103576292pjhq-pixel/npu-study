8","updated":"20260424101900"},"Children":[{"ID":"20260424101900-6llq0yn","Type":"NodeParagraph","Properties":{"id":"20260424101900-6llq0yn","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"乘法和加法由哪个最小单元执行"}]}]},{"ID":"20260424101900-l1kiwaq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-l1kiwaq","updated":"20260424101900"},"Children":[{"ID":"20260424101900-hco663x","Type":"NodeParagraph","Properties":{"id":"20260424101900-hco663x","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"部分和在什么位置累积"}]}]},{"ID":"20260424101900-w8ikss1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-w8ikss1","updated":"20260424101900"},"Children":[{"ID":"20260424101900-jkoudwe","Type":"NodeParagraph","Properties":{"id":"20260424101900-jkoudwe","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"激活、权重、部分和怎样在阵列与存储之间流动"}]}]}]},{"ID":"20260424101900-jz2ybxb","Type":"NodeParagraph","Properties":{"id":"20260424101900-jz2ybxb","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"所以看任何 NPU 计算核心，第一视角都应该是"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"归约机器"},{"Type":"NodeText","Data":"​，不是“大模块拼盘”。"}]},{"ID":"20260424101900-nw6dyaf","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101900-nw6dyaf","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"2. MAC 是原子，PE 是工程上的最小执行单元"}]},{"ID":"20260424101900-faoxmkm","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260424101900-faoxmkm","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"2.1 MAC：Multiply-Accumulate"}]},{"ID":"20260424101900-h39k8e9","Type":"NodeParagraph","Properties":{"id":"20260424101900-h39k8e9","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"MAC 的逻辑很直接："}]},{"ID":"20260424101900-ud80gry","Type":"NodeParagraph","Properties":{"id":"20260424101900-ud80gry","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"psum = psum + a * b"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101900-vzxnqb0","Type":"NodeParagraph","Properties":{"id":"20260424101900-vzxnqb0","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"但真正做硬件时，MAC 并不只是一个乘法器加一个加法器，还要同时处理："}]},{"ID":"20260424101900-hl88zob","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-hl88zob","updated":"20260424101900"},"Children":[{"ID":"20260424101900-o84m0ko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-o84m0ko","updated":"20260424101900"},"Children":[{"ID":"20260424101900-pxyjju0","Type":"NodeParagraph","Properties":{"id":"20260424101900-pxyjju0","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"输入位宽"}]}]},{"ID":"20260424101900-ybk517v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-ybk517v","updated":"20260424101900"},"Children":[{"ID":"20260424101900-1t127wm","Type":"NodeParagraph","Properties":{"id":"20260424101900-1t127wm","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"累加位宽"}]}]},{"ID":"20260424101900-6svrfuw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-6svrfuw","updated":"20260424101900"},"Children":[{"ID":"20260424101900-5h0sz9j","Type":"NodeParagraph","Properties":{"id":"20260424101900-5h0sz9j","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"pipeline 深度"}]}]},{"ID":"20260424101900-3dibw4i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-3dibw4i","updated":"20260424101900"},"Children":[{"ID":"20260424101900-oaaijqd","Type":"NodeParagraph","Properties":{"id":"20260424101900-oaaijqd","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"饱和 / 截断 / 舍入策略"}]}]},{"ID":"20260424101900-vv