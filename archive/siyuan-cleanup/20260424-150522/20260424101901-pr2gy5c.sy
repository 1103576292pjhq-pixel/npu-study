02"},"Children":[{"Type":"NodeText","Data":"读取工件元数据"}]}]},{"ID":"20260424101902-sp5ianr","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260424101902-sp5ianr","updated":"20260424101902"},"Children":[{"ID":"20260424101902-whcno9b","Type":"NodeParagraph","Properties":{"id":"20260424101902-whcno9b","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"分配或绑定执行所需缓冲区"}]}]},{"ID":"20260424101902-f8r5wji","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20260424101902-f8r5wji","updated":"20260424101902"},"Children":[{"ID":"20260424101902-v0789lt","Type":"NodeParagraph","Properties":{"id":"20260424101902-v0789lt","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"解析 kernel / command / descriptor"}]}]},{"ID":"20260424101902-1q93wv5","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20260424101902-1q93wv5","updated":"20260424101902"},"Children":[{"ID":"20260424101902-nyiy7br","Type":"NodeParagraph","Properties":{"id":"20260424101902-nyiy7br","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"建立 runtime 句柄与资源关系"}]}]}]},{"ID":"20260424101902-a3p6ef5","Type":"NodeParagraph","Properties":{"id":"20260424101902-a3p6ef5","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"这说明“模型加载”不是单纯文件 IO，而是把静态工件转为："}]},{"ID":"20260424101902-b3xucfa","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-b3xucfa","updated":"20260424101902"},"Children":[{"ID":"20260424101902-s4me89d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-s4me89d","updated":"20260424101902"},"Children":[{"ID":"20260424101902-x816c3m","Type":"NodeParagraph","Properties":{"id":"20260424101902-x816c3m","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"可访问的指令或命令缓冲"}]}]},{"ID":"20260424101902-4uqo7o7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-4uqo7o7","updated":"20260424101902"},"Children":[{"ID":"20260424101902-0lclfwh","Type":"NodeParagraph","Properties":{"id":"20260424101902-0lclfwh","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"已绑定的 tensor 视图"}]}]},{"ID":"20260424101902-h49p0ho","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-h49p0ho","updated":"20260424101902"},"Children":[{"ID":"20260424101902-2cyu1vq","Type":"NodeParagraph","Properties":{"id":"20260424101902-2cyu1vq","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"可提交的执行实例"}]}]}]},{"ID":"20260424101902-pkzyahp","Type":"NodeParagraph","Properties":{"id":"20260424101902-pkzyahp","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"所以一旦模型格式、内存布局、runtime 版本不一致，问题往往会在装载阶段就暴露，而不是等到真正执行时才发现。"}]},{"ID":"20260424101902-gv0zp1l","Type":"NodeParagraph","Properties":{"id":"20260424101902-gv0zp1l","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"拿 OpenVINO NPU 官方路径做例子，这条链不会停在“把 IR 读进来”。用户是通过 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"core.compile_model(model, \"NPU\")"},{"Type":"NodeText","Data":"​ 让 NPU plugin 把模型编译成设备可执行表示；如果开启 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ov::cache_dir"},{"Type":"NodeText","Data":"​，第一次编译后的工件会进入 OpenVINO cache，后续 cache hit 时插件直接 import model，而不是重新 compile。也就是说，runtime 面对的通常不是原始训练模型，而是“已编译模型 / 可导入工件”的生命周期管理。"}]},{"ID":"20260424101902-gys3qrl","Type":"NodeParagraph","Properties":{"id":"20260424101902-gys3qrl","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"官方文档还明确写了两个容易被忽视的边界：当前 NPU 路径强调 static shape 支持；offline compilation 和 blob import 只建议开发用途，跨 OpenVINO 版本的 blob 兼容性并不保证。缓存能降低首轮启动延迟，但它不会自动抹掉平台版本边界。"}]},{"ID":"20260424101902-rp9w0jj","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101902-rp9w0jj","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"5. 内存管理：系统集成里最容易出事的一层"}]},{"ID":"20260424101902-7vljf9j","Type":"NodeParagraph","Properties":{"id":"20260424101902-7vljf9j","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"NPU 运行时至少要同时处理三类内存问题："}]},{"ID":"20260424101902-n6kbclx","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-n6kbclx","updated":"20260424101902"},"Children":[{"ID":"20260424101902-gn7mrwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-gn7mrwv","updated":"20260424101902"},"Children":[{"ID":"20260424101902-fevti6k","Type":"NodeParagraph","Properties":{"id":"20260424101902-fevti6k","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Host 内存"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101902-vce4ykw","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-vce4ykw","updated":"20260424101902"},"Children":[{"ID":"20260424101902-kdgo1ch","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-kdgo1ch","updated":"20260424101902"},"Children":[{"ID":"20260424101902-us2tiup","Type":"NodeParagraph","Properties":{"id":"20260424101902-us2tiup","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"应用和 runtime 能直接访问"}]}]}]}]},{"ID":"20260424101902-6pmcknp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-6pmcknp","updated":"20260424101902"},"Children":[{"ID":"20260424101902-vk1b3hj","Type":"NodeParagraph","Properties":{"id":"20260424101902-vk1b3hj","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Device 内存"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101902-5js20ef","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-5js20ef","updated":"20260424101902"},"Children":[{"ID":"20260424101902-v43w2ye","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-v43w2ye","updated":"20260424101902"},"Children":[{"ID":"20260424101902-plbi45m","Type":"NodeParagraph","Properties":{"id":"20260424101902-plbi45m","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"NPU 真正执行时使用"}]}]}]}]},{"ID":"20260424101902-au6wxt5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-au6wxt5","updated":"20260424101902"},"Children":[{"ID":"20260424101902-aos756f","Type":"NodeParagraph","Properties":{"id":"20260424101902-aos756f","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Host \u0026lt;-\u0026gt; Device 传输"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101902-1cuwqb7","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-1cuwqb7","updated":"20260424101902"},"Children":[{"ID":"20260424101902-5hjhyyy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-5hjhyyy","updated":"20260424101902"},"Children":[{"ID":"20260424101902-m9i6pwp","Type":"NodeParagraph","Properties":{"id":"20260424101902-m9i6pwp","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"H2D / D2H、zero-copy、映射、cache 一致性"}]}]}]}]}]},{"ID":"20260424101902-ocz06re","Type":"NodeParagraph","Properties":{"id":"20260424101902-ocz06re","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"在 Linux 系统里，经常还会遇到："}]},{"ID":"20260424101902-rqowelz","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-rqowelz","updated":"20260424101902"},"Children":[{"ID":"20260424101902-id3d8jz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-id3d8jz","updated":"20260424101902"},"Children":[{"ID":"20260424101902-cngxrrl","Type":"NodeParagraph","Properties":{"id":"20260424101902-cngxrrl","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"CMA"}]}]},{"ID":"20260424101902-hg3rhyq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-hg3rhyq","updated":"20260424101902"},"Children":[{"ID":"20260424101902-89h6jql","Type":"NodeParagraph","Properties":{"id":"20260424101902-89h6jql","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"ION 或等价分配器"}]}]},{"ID":"20260424101902-07plpkb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-07plpkb","updated":"20260424101902"},"Children":[{"ID":"20260424101902-c7xi9au","Type":"NodeParagraph","Properties":{"id":"20260424101902-c7xi9au","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"DMA mapping API"}]}]},{"ID":"20260424101902-hwtqlj8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-hwtqlj8","updated":"20260424101902"},"Children":[{"ID":"20260424101902-684812o","Type":"NodeParagraph","Properties":{"id":"20260424101902-684812o","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"用户态 mmap"}]}]}]},{"ID":"20260424101902-buz801h","Type":"NodeParagraph","Properties":{"id":"20260424101902-buz801h","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"这层如果没处理好，最典型的问题就是："}]},{"ID":"20260424101902-4secs26","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101902-4secs26","updated":"20260424101902"},"Children":[{"ID":"20260424101902-ffgvxp0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-ffgvxp0","updated":"20260424101902"},"Children":[{"ID":"20260424101902-eprhu68","Type":"NodeParagraph","Properties":{"id":"20260424101902-eprhu68","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"复制次数太多"}]}]},{"ID":"20260424101902-qrj3ak3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-qrj3ak3","updated":"20260424101902"},"Children":[{"ID":"20260424101902-ge6vh1c","Type":"NodeParagraph","Properties":{"id":"20260424101902-ge6vh1c","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"cache 不一致"}]}]},{"ID":"20260424101902-t6l585e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-t6l585e","updated":"20260424101902"},"Children":[{"ID":"20260424101902-y3om394","Type":"NodeParagraph","Properties":{"id":"20260424101902-y3om394","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"对齐和粒度不匹配"}]}]},{"ID":"20260424101902-z8odwwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101902-z8odwwv","updated":"20260424101902"},"Children":[{"ID":"20260424101902-ks2dsut","Type":"NodeParagraph","Properties":{"id":"20260424101902-ks2dsut","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"大块连续内存难分配"}]}]}]},{"ID":"20260424101902-mt1t04v","Type":"NodeParagraph","Properties":{"id":"20260424101902-mt1t04v","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"所以运行时和驱动里，内存管理不是配角，它常常直接决定端到端延迟和稳定性。"}]},{"ID":"20260424101902-i8h44c8","Type":"NodeParagraph","Properties":{"id":"20260424101902-i8h44c8","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"一个很实用的系统问题是："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"一次推理到底发生了几次复制"},{"Type":"NodeText","Data":"​。如果这个问题回答不清，runtime 层的很多“优化”都可能只是把复制位置换了一下，并没有真正把延迟压下去。"}]},{"ID":"20260424101902-2blovvs","Type":"NodeParagraph","Properties":{"id":"20260424101902-2blovvs","updated":"20260424101902"},"Children":[{"Type":"NodeText","Data":"再往系统外看一步，OpenVINO 的 NPU 配置文档也提醒了一个现实约束：NPU 能不能用，不只取决于 API，还取决于 host driver 和 OS 前提。Windows 侧通常依赖系统驱动分发或手动安装 NPU driver；Ubuntu 侧则明确给出了版本和内核下限。把这些前提漏掉，运行时问题就很容易被误判成“模型或算子问题”。"}]},{"ID":"20260424101902-7kepn6g","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101902-7kepn6g","updated":"20260424101902"},"Childr