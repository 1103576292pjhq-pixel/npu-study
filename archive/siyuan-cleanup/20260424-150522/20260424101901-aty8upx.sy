24101901-vm3cgs8","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"很多编译问题的关键，不是“怎么让一个算子跑更快”，而是“它值不值得上 NPU”。"}]},{"ID":"20260424101901-hj09ci5","Type":"NodeParagraph","Properties":{"id":"20260424101901-hj09ci5","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"子图划分时至少要看："}]},{"ID":"20260424101901-f777fuk","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101901-f777fuk","updated":"20260424101901"},"Children":[{"ID":"20260424101901-8httupz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-8httupz","updated":"20260424101901"},"Children":[{"ID":"20260424101901-rbeitvd","Type":"NodeParagraph","Properties":{"id":"20260424101901-rbeitvd","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"算子是否被目标 NPU 支持"}]}]},{"ID":"20260424101901-xp8fnxd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-xp8fnxd","updated":"20260424101901"},"Children":[{"ID":"20260424101901-qkv6wda","Type":"NodeParagraph","Properties":{"id":"20260424101901-qkv6wda","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"shape 和 layout 是否落在高效区间"}]}]},{"ID":"20260424101901-fc2curr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-fc2curr","updated":"20260424101901"},"Children":[{"ID":"20260424101901-0n3io4j","Type":"NodeParagraph","Properties":{"id":"20260424101901-0n3io4j","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"是否能与前后算子形成融合块"}]}]},{"ID":"20260424101901-5bvy7pc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-5bvy7pc","updated":"20260424101901"},"Children":[{"ID":"20260424101901-niqleyk","Type":"NodeParagraph","Properties":{"id":"20260424101901-niqleyk","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"上下文切换和数据回传成本是否超过收益"}]}]}]},{"ID":"20260424101901-rqygipd","Type":"NodeParagraph","Properties":{"id":"20260424101901-rqygipd","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"这也是为什么像 TVM BYOC、OpenVINO 插件、ACL 这类体系都强调："}]},{"ID":"20260424101901-zt41nt4","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101901-zt41nt4","updated":"20260424101901"},"Children":[{"ID":"20260424101901-l658izr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-l658izr","updated":"20260424101901"},"Children":[{"ID":"20260424101901-bkprc71","Type":"NodeParagraph","Properties":{"id":"20260424101901-bkprc71","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"分区"}]}]},{"ID":"20260424101901-m1g6zrp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-m1g6zrp","updated":"20260424101901"},"Children":[{"ID":"20260424101901-gkksm11","Type":"NodeParagraph","Properties":{"id":"20260424101901-gkksm11","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"delegate / backend / plugin"}]}]},{"ID":"20260424101901-crzddwq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-crzddwq","updated":"20260424101901"},"Children":[{"ID":"20260424101901-spjh3oh","Type":"NodeParagraph","Properties":{"id":"20260424101901-spjh3oh","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"heterogeneous execution"}]}]}]},{"ID":"20260424101901-kmqyx5n","Type":"NodeParagraph","Properties":{"id":"20260424101901-kmqyx5n","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"因为真实系统里，NPU 往往只是异构系统中的一个执行目标，不是唯一目标。"}]},{"ID":"20260424101901-ud87yzv","Type":"NodeParagraph","Properties":{"id":"20260424101901-ud87yzv","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"以 TVM BYOC 为例，官方给出的不是“某个算子注册一个回调”这么简单，而是 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"annotate candidates -\u0026gt; partition graph -\u0026gt; 把每个子图交给 backend codegen -\u0026gt; 返回 runtime.Module -\u0026gt; 与剩余图一起链接"},{"Type":"NodeText","Data":"​。这个流程说明三件事："}]},{"ID":"20260424101901-2b9gz6s","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101901-2b9gz6s","updated":"20260424101901"},"Children":[{"ID":"20260424101901-ab6sy5c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-ab6sy5c","updated":"20260424101901"},"Children":[{"ID":"20260424101901-46wszmy","Type":"NodeParagraph","Properties":{"id":"20260424101901-46wszmy","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"BYOC 的基本单位是子图，不是单个 API 钩子"}]}]},{"ID":"20260424101901-cy6rp4w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-cy6rp4w","updated":"20260424101901"},"Children":[{"ID":"20260424101901-zu1dcv8","Type":"NodeParagraph","Properties":{"id":"20260424101901-zu1dcv8","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"partition 一旦做错，后面 codegen 和 runtime 只是在被动吃结果"}]}]},{"ID":"20260424101901-4vbinoo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-4vbinoo","updated":"20260424101901"},"Children":[{"ID":"20260424101901-3zvucew","Type":"NodeParagraph","Properties":{"id":"20260424101901-3zvucew","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"heterogeneous execution 不是补丁，而是编译期结构化决策"}]}]}]},{"ID":"20260424101901-56m7n1p","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101901-56m7n1p","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"6. 算子映射：从语义算子到硬件原语"}]},{"ID":"20260424101901-r5zynnm","Type":"NodeParagraph","Properties":{"id":"20260424101901-r5zynnm","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"编译器在做算子映射时，常见三种情况："}]},{"ID":"20260424101901-6bfygzd","Type":"NodeTable","TableAligns":[0,0,0],"Properties":{"colgroup":"||","id":"20260424101901-6bfygzd","updated":"20260424101901"},"Children":[{"Type":"NodeTableHead","Data":"thead","C