"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20260424101859-a0p09go","updated":"20260424101859"},"Children":[{"ID":"20260424101859-j96bzo8","Type":"NodeParagraph","Properties":{"id":"20260424101859-j96bzo8","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"架构通过什么方式缓解这个最贵项。"}]}]},{"ID":"20260424101859-n7abdpd","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NC4=","Num":4},"Properties":{"id":"20260424101859-n7abdpd","updated":"20260424101859"},"Children":[{"ID":"20260424101859-f06vrd6","Type":"NodeParagraph","Properties":{"id":"20260424101859-f06vrd6","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"为此牺牲了哪些灵活性或软件复杂度。"}]}]},{"ID":"20260424101859-tat80rw","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20260424101859-tat80rw","updated":"20260424101859"},"Children":[{"ID":"20260424101859-b7kvlvu","Type":"NodeParagraph","Properties":{"id":"20260424101859-b7kvlvu","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"这些牺牲是否符合目标场景。"}]}]}]},{"ID":"20260424101859-c3i1jvj","Type":"NodeParagraph","Properties":{"id":"20260424101859-c3i1jvj","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"举例："}]},{"ID":"20260424101859-tgv49k5","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-tgv49k5","updated":"20260424101859"},"Children":[{"ID":"20260424101859-80g9n9b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-80g9n9b","updated":"20260424101859"},"Children":[{"ID":"20260424101859-um3d18t","Type":"NodeParagraph","Properties":{"id":"20260424101859-um3d18t","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"边缘端 NPU 往往把预算押在低功耗、低精度、固定功能块和轻量 runtime 上。"}]}]},{"ID":"20260424101859-75iekju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-75iekju","updated":"20260424101859"},"Children":[{"ID":"20260424101859-kr6jos9","Type":"NodeParagraph","Properties":{"id":"20260424101859-kr6jos9","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"云端或高性能平台会更重视可扩展性、编程模型、内存系统与多核协同。"}]}]}]},{"ID":"20260424101859-e4gwgjo","Type":"NodeParagraph","Properties":{"id":"20260424101859-e4gwgjo","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"结构不是孤立选择，它总是对着某个瓶颈和某个场景作出的。"}]},{"ID":"20260424101859-93ch75a","Type":"NodeParagraph","Properties":{"id":"20260424101859-93ch75a","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"所以真正做问题定义时，最怕的不是“信息不够多”，而是跳过了这一步，直接谈阵列或 TOPS。"}]},{"ID":"20260424101859-ouz9hg9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-ouz9hg9","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"10. 本卷之后应该得到的判断能力"}]},{"ID":"20260424101859-ydqovkb","Type":"NodeParagraph","Properties":{"id":"20260424101859-ydqovkb","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"至少能回答："}]},{"ID":"20260424101859-7ffb76t","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-7ffb76t","updated":"20260424101859"},"Children":[{"ID":"20260424101859-vuew743","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-vuew743","updated":"20260424101859"},"Children":[{"ID":"20260424101859-gxw5kqr","Type":"NodeParagraph","Properties":{"id":"20260424101859-gxw5kqr","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"为什么 AI 负载会逼出 NPU 这种专用架构，而不是继续只靠 CPU/GPU。"}]}]},{"ID":"20260424101859-e319b7t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-e319b7t","updated":"20260424101859"},"Children":[{"ID":"20260424101859-7qaz1ul","Type":"NodeParagraph","Properties":{"id":"20260424101859-7qaz1ul","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"为什么 NPU 的核心价值在“有效吞吐/能效/部署成本”，不是单一峰值算力。"}]}]},{"ID":"20260424101859-ff06v4b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-ff06v4b","updated":"20260424101859"},"Children":[{"ID":"20260424101859-0ki2oa7","Type":"NodeParagraph","Properties":{"id":"20260424101859-0ki2oa7","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"为什么 NPU 从定义上就离不开编译器、runtime 和系统集成。"}]}]},{"ID":"20260424101859-xfjd4nt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-xfjd4nt","updated":"20260424101859"},"Children":[{"ID":"20260424101859-051xce2","Type":"NodeParagraph","Properties":{"id":"20260424101859-051xce2","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"为什么任何架构讨论都必须带着工作负载和场景一起看。"}]}]}]},{"ID":"20260424101859-vpzfe75","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-vpzfe75","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"11. 常见误区"}]},{"ID":"20260424101859-0mb701i","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-0mb701i","updated":"20260424101859"},"Children":[{"ID":"20260424101859-bl5rkkt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-bl5rkkt","updated":"20260424101859"},"Children":[{"ID":"20260424101859-j98zw2i","Type":"NodeParagraph","Properties":{"id":"20260424101859-j98zw2i","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"NPU 就是 AI 版 GPU"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-0yihifz","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-0yihifz","updated":"20260424101859"},"Children":[{"ID":"20260424101859-n012ubp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-n012ubp","updated":"20260424101859"},"Children":[{"ID":"20260424101859-se2y295","Type":"NodeParagraph","Properties":{"id":"20260424101859-se2y295","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"修正：两者都能做张量计算，但默认优化目标、控制方式、功耗预算和系统位置并不一样。"}]}]}]}]},{"ID":"20260424101859-3nn3pta","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-3nn3pta","updated":"20260424101859"},"Children":[{"ID":"20260424101859-a5tjmd0","Type":"NodeParagraph","Properties":{"id":"20260424101859-a5tjmd0","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"有了 NPU，CPU/GPU 就不重要了"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-hrdbo79","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-hrdbo79","updated":"20260424101859"},"Children":[{"ID":"20260424101859-f4yfr4x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-f4yfr4x","updated":"20260424101859"},"Children":[{"ID":"20260424101859-docwnfs","Type":"NodeParagraph","Properties":{"id":"20260424101859-docwnfs","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"修正：CPU 负责系统控制，GPU 在许多训练和通用并行场景仍然关键，NPU 只是重新分工，不是替代一切。"}]}]}]}]},{"ID":"20260424101859-h9uvpry","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-h9uvpry","updated":"20260424101859"},"Children":[{"ID":"20260424101859-za8jmtc","Type":"NodeParagraph","Properties":{"id":"20260424101859-za8jmtc","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"NPU 只和硬件工程师有关"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-vecjcml","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-vecjcml","updated":"20260424101859"},"Children":[{"ID":"20260424101859-pyxyfe4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-pyxyfe4","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ri8ii03","Type":"NodeParagraph","Properties":{"id":"20260424101859-ri8ii03","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"修正：没有编译器、runtime、驱动和框架接入，NPU 的大部分价值无法兑现。"}]}]}]}]},{"ID":"20260424101859-i6m3jxo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-i6m3jxo","updated":"20260424101859"},"Children":[{"ID":"20260424101859-4g832se","Type":"NodeParagraph","Properties":{"id":"20260424101859-4g832se","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"只要模型能跑起来，架构就算成功"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-bgam1uo","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-bgam1uo","updated":"20260424101859"},"Children":[{"ID":"20260424101859-85a15pb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-85a15pb","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ddr4ecu","Type":"NodeParagraph","Properties":{"id":"20260424101859-ddr4ecu","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"修正：真正的成功标准是目标场景下的性能、功耗、成本、软件可维护性一起过关。"}]}]}]}]}]},{"ID":"20260424101859-bdjqc3o","Type":"NodeParagraph","Properties":{"id":"20260424101859-bdjqc3o","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"这一卷的任务只有一个：把“为什么是 NPU”这件事说清楚。只有问题定义稳定，后面的阵列、数据流、量化、编译与系统章节才不会散掉。"}]},{"ID":"20260424101859-g96wfbo","Type":"NodeParagraph","Properties":{"id":"20260424101859-g96wfbo","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"下一卷开始收缩视角，不再讨论“为什么需要”，而是进入“真正执行乘加的核心究竟长什么样、为什么长成这样”。"}]}]}