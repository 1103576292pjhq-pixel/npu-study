101859-z5nvojg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-z5nvojg","updated":"20260424101859"},"Children":[{"ID":"20260424101859-cvs33nk","Type":"NodeParagraph","Properties":{"id":"20260424101859-cvs33nk","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"指令取用、分支预测、乱序执行等机制对规则乘加不是最省能的路径"}]}]},{"ID":"20260424101859-o12co86","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-o12co86","updated":"20260424101859"},"Children":[{"ID":"20260424101859-91e6mro","Type":"NodeParagraph","Properties":{"id":"20260424101859-91e6mro","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"缓存对 AI 张量的复用方向不一定友好"}]}]}]},{"ID":"20260424101859-fu5x82u","Type":"NodeParagraph","Properties":{"id":"20260424101859-fu5x82u","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"所以 CPU 在 NPU 系统里通常更像："}]},{"ID":"20260424101859-sgdgzlm","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-sgdgzlm","updated":"20260424101859"},"Children":[{"ID":"20260424101859-oswvo22","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-oswvo22","updated":"20260424101859"},"Children":[{"ID":"20260424101859-apd14lg","Type":"NodeParagraph","Properties":{"id":"20260424101859-apd14lg","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"系统主控"}]}]},{"ID":"20260424101859-0cmsy7x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-0cmsy7x","updated":"20260424101859"},"Children":[{"ID":"20260424101859-yr4si5f","Type":"NodeParagraph","Properties":{"id":"20260424101859-yr4si5f","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"runtime 承载者"}]}]},{"ID":"20260424101859-g5b6aue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-g5b6aue","updated":"20260424101859"},"Children":[{"ID":"20260424101859-yc1lubp","Type":"NodeParagraph","Properties":{"id":"20260424101859-yc1lubp","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"NPU 命令与内存管理的协调者"}]}]}]},{"ID":"20260424101859-j7yltzb","Type":"NodeParagraph","Properties":{"id":"20260424101859-j7yltzb","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"而不是主要算力来源。"}]},{"ID":"20260424101859-6r33tv2","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-6r33tv2","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"4. GPU 很强，但它优化的是另一种“高吞吐”"}]},{"ID":"20260424101859-lxolv4x","Type":"NodeParagraph","Properties":{"id":"20260424101859-lxolv4x","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"GPU 比 CPU 更接近 AI 计算需求，因为它天然擅长大规模并行。但 GPU 仍然不是所有场景下最优的 NPU 替代物。"}]},{"ID":"20260424101859-7csgm7i","Type":"NodeParagraph","Properties":{"id":"20260424101859-7csgm7i","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"GPU 的强项："}]},{"ID":"20260424101859-sjopsk8","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-sjopsk8","updated":"20260424101859"},"Children":[{"ID":"20260424101859-2q4snz6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-2q4snz6","updated":"20260424101859"},"Children":[{"ID":"20260424101859-0ylv6lx","Type":"NodeParagraph","Properties":{"id":"20260424101859-0ylv6lx","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"大规模线程并发"}]}]},{"ID":"20260424101859-t2xn9ko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-t2xn9ko","updated":"20260424101859"},"Children":[{"ID":"20260424101859-k672a82","Type":"NodeParagraph","Properties":{"id":"20260424101859-k672a82","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"高吞吐浮点与张量运算"}]}]},{"ID":"20260424101859-mfhn6au","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-mfhn6au","updated":"20260424101859"},"Children":[{"ID":"20260424101859-sqdvg6a","Type":"NodeParagraph","Properties":{"id":"20260424101859-sqdvg6a","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"成熟的软件生态"}]}]},{"ID":"20260424101859-p5bcfkm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-p5bcfkm","updated":"20260424101859"},"Children":[{"ID":"20260424101859-y8aibpg","Type":"NodeParagraph","Properties":{"id":"20260424101859-y8aibpg","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"训练和通用并行计算都能覆盖"}]}]}]},{"ID":"20260424101859-lkj7of6","Type":"NodeParagraph","Properties":{"id":"20260424101859-lkj7of6","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"GPU 的局限："}]},{"ID":"20260424101859-jmls8go","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-jmls8go","updated":"20260424101859"},"Children":[{"ID":"20260424101859-k2ckicm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-k2ckicm","updated":"20260424101859"},"Children":[{"ID":"20260424101859-fmdpzyw","Type":"NodeParagraph","Properties":{"id":"20260424101859-fmdpzyw","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"线程调度、寄存器管理、缓存层级仍然服务于更通用的执行模型"}]}]},{"ID":"20260424101859-u1rihl5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-u1rihl5","updated":"20260424101859"},"Children":[{"ID":"20260424101859-2dtbg9l","Type":"NodeParagraph","Properties":{"id":"20260424101859-2dtbg9l","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"对边缘端、低功耗端来说，能效和成本不一定合适"}]}]},{"ID":"20260424101859-ljn9589","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-ljn9589","updated":"20260424101859"},"Children":[{"ID":"20260424101859-jslbu3z","Type":"NodeParagraph","Properties":{"id":"20260424101859-jslbu3z","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"若工作负载已知且规则，GPU 的灵活性本身就是一部分额外成本"}]}]}]},{"ID":"20260424101859-6np1x53","Type":"NodeParagraph","Properties":{"id":"20260424101859-6np1x53","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"一句话概括："}]},{"ID":"20260424101859-q7y69s8","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-q7y69s8","updated":"20260424101859"},"Children":[{"ID":"20260424101859-uvvncw1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-uvvncw1","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ec5vvgc","Type":"NodeParagraph","Properties":{"id":"20260424101859-ec5vvgc","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"CPU"},{"Type":"NodeText","Data":"​ 像系统指挥部"}]}]},{"ID":"20260424101859-fi9zen7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-fi9zen7","updated":"20260424101859"},"Children":[{"ID":"20260424101859-0ps74rs","Type":"NodeParagraph","Properties":{"id":"20260424101859-0ps74rs","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"GPU"},{"Type":"NodeText","Data":"​ 像大规模并行工厂"}]}]},{"ID":"20260424101859-cfbjtql","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-cfbjtql","updated":"20260424101859"},"Children":[{"ID":"20260424101859-vkdqiet","Type":"NodeParagraph","Properties":{"id":"20260424101859-vkdqiet","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"FPGA"},{"Type":"NodeText","Data":"​ 像可重构实验平台"}]}]},{"ID":"20260424101859-avq0fic","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-avq0fic","updated":"20260424101859"},"Children":[{"ID":"20260424101859-5y6lj0f","Type":"NodeParagraph","Properties":{"id":"20260424101859-5y6lj0f","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"NPU"},{"Type":"NodeText","Data":"​ 像围绕 AI 主负载做过深度工艺化裁剪的专用产线"}]}]}]},{"ID":"20260424101859-fsxbsfp","Type":"NodeParagraph","Properties":{"id":"20260424101859-fsxbsfp","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"所以很多边缘端或 SoC 场景里，系统不会问“GPU 能不能算”，而会问："}]},{"ID":"20260424101859-9jz05w0","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-9jz05w0","updated":"20260424101859"},"Children":[{"ID":"20260424101859-vvw51ik","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-vvw51ik","updated":"20260424101859"},"Children":[{"ID":"20260424101859-nxbgqlq","Type":"NodeParagraph","Properties":{"id":"20260424101859-nxbgqlq","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"在 1W、2W、5W 这种功耗壳里，GPU 算得是否划算"}]}]},{"ID":"20260424101859-sx6pj12","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-sx6pj12","updated":"20260424101859"},"Children":[{"ID":"20260424101859-g2hl9s1","Type":"NodeParagraph","Properties":{"id":"20260424101859-g2hl9s1","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"在手机/摄像头/车载 SoC 里，GPU 是否值得为某个固定 AI 负载一直保留这么高的通用性"}]}]}]},{"ID":"20260424101859-itfylrq","Type":"NodeParagraph","Properties":{"id":"20260424101859-itfylrq","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"这恰恰是 NPU 的切入点。"}]},{"ID":"20260424101859-osu630c","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-osu630c","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"5. FPGA 的角色：可重构，但不天然适合作为统一结论"}]},{"ID":"20260424101859-zg8jn94","Type":"NodeParagraph","Properties":{"id":"20260424101859-zg8jn94","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"FPGA 很适合："}]},{"ID":"20260424101859-ku2zlyf","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-ku2zlyf","updated":"20260424101859"},"Children":[{"ID":"20260424101859-eil2m1u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-eil2m1u","updated":"20260424101859"},"Children":[{"ID":"20260424101859-l9rccda","Type":"NodeParagraph","Properties":{"id":"20260424101859-l9rccda","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"快速验证新数据流"}]}]},{"ID":"20260424101859-wpf7ize","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-wpf7ize","updated":"20260424101859"},"Children":[{"ID":"20260424101859-nvoduf3","Type":"NodeParagraph","Properties":{"id":"20260424101859-nvoduf3","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"尝试特殊位宽和特殊算子"}]}]},{"ID":"20260424101859-bk1yjw5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-bk1yjw5","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ebdc74k","Type":"NodeParagraph","Properties":{"id":"20260424101859-ebdc74k","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"在需求变化大时保留灵活性"}]}]}]},{"ID":"20260424101859-883qbm6","Type":"NodeParagraph","Properties":{"id":"20260424101859-883qbm6","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"但 FPGA 不是 NPU 设计讨论的默认终点，因为："}]},{"ID":"20260424101859-bjiptyb","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-bjiptyb","updated":"20260424101859"},"Children":[{"ID":"20260424101859-7ueyazd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-7ueyazd","updated":"20260424101859"},"Children":[{"ID":"20260424101859-0sh4xpx","Type":"NodeParagraph","Properties":{"id":"20260424101859-0sh4xpx","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"面积效率通常不如 ASIC/IP"}]}]},{"ID":"20260424101859-te7lmlc","Type":"NodeListItem","ListData":{"B