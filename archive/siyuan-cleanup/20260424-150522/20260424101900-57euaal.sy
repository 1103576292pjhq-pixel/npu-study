1901-9xoo0gh","updated":"20260424101901"},"Children":[{"ID":"20260424101901-0m50xz6","Type":"NodeParagraph","Properties":{"id":"20260424101901-0m50xz6","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"修正：量化会改变 tile 和带宽预算，融合会改变中间张量驻留，稀疏会改变访存与调度，三者必须合起来看。"}]}]}]}]}]},{"ID":"20260424101901-lrzz6qj","Type":"NodeParagraph","Properties":{"id":"20260424101901-lrzz6qj","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"这一卷建立的是第二条系统因果链："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"少位宽 / 少非零 / 少中间结果 -\u0026gt; 少搬运 / 少存储 / 少无效计算 -\u0026gt; 更高有效吞吐和能效"},{"Type":"NodeText","Data":"​。下一卷会继续沿着这条链往软件栈推进，讨论编译器如何把这些优化真正编排成 NPU 可以执行的计划。"}]}]}