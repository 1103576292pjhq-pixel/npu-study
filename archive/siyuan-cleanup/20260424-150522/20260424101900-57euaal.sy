"},"Children":[{"ID":"20260424101901-nxgfc22","Type":"NodeParagraph","Properties":{"id":"20260424101901-nxgfc22","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"修正：真正困难的是校准、累加位宽、敏感层和部署路径，而不是改一个数据类型名字。"}]}]}]}]},{"ID":"20260424101901-4hxxd1m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-4hxxd1m","updated":"20260424101901"},"Children":[{"ID":"20260424101901-1wdh40e","Type":"NodeParagraph","Properties":{"id":"20260424101901-1wdh40e","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"模型很稀疏，所以硬件一定更快"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101901-hzbgv84","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101901-hzbgv84","updated":"20260424101901"},"Children":[{"ID":"20260424101901-ofpgkl6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-ofpgkl6","updated":"20260424101901"},"Children":[{"ID":"20260424101901-xwugl4r","Type":"NodeParagraph","Properties":{"id":"20260424101901-xwugl4r","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"修正：没有规整编码和均衡调度时，稀疏反而可能让阵列更难喂。"}]}]}]}]},{"ID":"20260424101901-gzpov7c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-gzpov7c","updated":"20260424101901"},"Children":[{"ID":"20260424101901-5jhc52z","Type":"NodeParagraph","Properties":{"id":"20260424101901-5jhc52z","updated":"20260424101901"},"Children":[{"Type":"NodeText","Data":"误区："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"融合只是编译器的小技巧"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101901-cmn2m1v","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101901-cmn2m1v","updated":"20260424101901"},"Children":[{"ID":"20260424101901-uxl3z9y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101901-uxl3z9y","updated