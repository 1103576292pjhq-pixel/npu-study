tData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260424101900-fmd61bx","updated":"20260424101900"},"Children":[{"ID":"20260424101900-o8e2gb7","Type":"NodeParagraph","Properties":{"id":"20260424101900-o8e2gb7","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"稳定执行节拍"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101900-fw1gma2","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-fw1gma2","updated":"20260424101900"},"Children":[{"ID":"20260424101900-1635kin","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-1635kin","updated":"20260424101900"},"Children":[{"ID":"20260424101900-gej2psg","Type":"NodeParagraph","Properties":{"id":"20260424101900-gej2psg","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"让计算、搬运、回写形成预测性很强的流水。"}]}]}]}]}]},{"ID":"20260424101900-o01o9rs","Type":"NodeParagraph","Properties":{"id":"20260424101900-o01o9rs","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"所以硬件循环不是“循环语法的硬件版”，而是"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"专门为规则张量计算设计的执行模板控制器"},{"Type":"NodeText","Data":"​。"}]},{"ID":"20260424101900-scbp1x4","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101900-scbp1x4","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"5. Loop Tiling、Unrolling、Pipelining 为什么总成套出现"}]},{"ID":"20260424101900-zyo5o0t","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260424101900-zyo5o0t","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"5.1 Tiling：把问题切到片上能吃得下"}]},{"ID":"20260424101900-9r5swk1","Type":"NodeParagraph","Properties":{"id":"20260424101900-9r5swk1","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"不做 tiling，很多层根本放不进片上 buffer。做 tiling 以后，设计才开始真正出现复用。"}]},{"ID":"20260424101900-t2cgag9","Type":"NodeParagraph","Properties":{"id":"20260424101900-t2cgag9","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"一个 tile 切得对不对，至少要同时满足："}]},{"ID":"20260424101900-dqh3h37","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-dqh3h37","updated":"20260424101900"},"Children":[{"ID":"20260424101900-co0yv4p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-co0yv4p","updated":"20260424101900"},"Children":[{"ID":"20260424101900-shweqs9","Type":"NodeParagraph","Properties":{"id":"20260424101900-shweqs9","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"权重 tile 放得下"}]}]},{"ID":"20260424101900-zggywjb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-zggywjb","updated":"20260424101900"},"Children":[{"ID":"20260424101900-ihewthg","Type":"NodeParagraph","Properties":{"id":"20260424101900-ihewthg","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"激活 tile 放得下"}]}]},{"ID":"20260424101900-7kwblt0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-7kwblt0","updated":"20260424101900"},"Children":[{"ID":"20260424101900-v5x4ch7","Type":"NodeParagraph","Properties":{"id":"20260424101900-v5x4ch7","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"部分和 tile 放得下"}]}]},{"ID":"20260424101900-doxoykn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-doxoykn","updated":"20260424101900"},"Children":[{"ID":"20260424101900-kh93cu1","Type":"NodeParagraph","Properties":{"id":"20260424101900-kh93cu1","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"阵列可以持续吃这个 tile"}]}]},{"ID":"20260424101900-futj2l7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-futj2l7","updated":"20260424101900"},"Children":[{"ID":"20260424101900-9fhew7o","Type":"NodeParagraph","Properties":{"id":"20260424101900-9fhew7o","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"DMA 能在下一个 tile 到来前供完数据"}]}]}]},{"ID":"20260424101900-szr4az8","Type":"NodeParagraph","Properties":{"id":"20260424101900-szr4az8","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"tile 过小，DMA 和边界开销占比会高；tile 过大，片上放不下或并发不足。tile 选择不是纯数学问题，而是被 SRAM 容量、bank 数、阵列宽度和 DMA 粒度共同约束的。"}]},{"ID":"20260424101900-ch2fakl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260424101900-ch2fakl","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"5.2 Unrolling：把独立迭代摊到更多硬件上"}]},{"ID":"20260424101900-n71ej6j","Type":"NodeParagraph","Properties":{"id":"20260424101900-n71ej6j","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"循环展开会提高并行度，但副作用也很直接："}]},{"ID":"20260424101900-9ru92po","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-9ru92po","updated":"20260424101900"},"Children":[{"ID":"20260424101900-ig68dpb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-ig68dpb","updated":"20260424101900"},"Children":[{"ID":"20260424101900-ndkn1bn","Type":"NodeParagraph","Properties":{"id":"20260424101900-ndkn1bn","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"需要更多寄存器或局部 buffer"}]}]},{"ID":"20260424101900-ly5a161","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-ly5a161","updated":"20260424101900"},"Children":[{"ID":"20260424101900-v4ntp7k","Type":"NodeParagraph","Properties":{"id":"20260424101900-v4ntp7k","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"数据端口压力更大"}]}]},{"ID":"20260424101900-k4u6l11","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-k4u6l11","updated":"20260424101900"},"Children":[{"ID":"20260424101900-hrvqm46","Type":"NodeParagraph","Properties":{"id":"20260424101900-hrvqm46","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"可能放大访存冲突"}]}]}]},{"ID":"20260424101900-oqqfwj6","Type":"NodeParagraph","Properties":{"id":"20260424101900-oqqfwj6","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"所以“能展开多少”不是只看阵列空位，而要看供数链路扛不扛得住。"}]},{"ID":"20260424101900-u0egkfd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260424101900-u0egkfd","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"5.3 Pipelining：让不同阶段重叠起来"}]},{"ID":"20260424101900-hqy5e4s","Type":"NodeParagraph","Properties":{"id":"20260424101900-hqy5e4s","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"理想状态下，一个 tile 的读取、计算、回写不应串行排队，而应重叠进行。硬件流水化要解决的就是："}]},{"ID":"20260424101900-wtzxu4o","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-wtzxu4o","updated":"20260424101900"},"Children":[{"ID":"20260424101900-esu90ji","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-esu90ji","updated":"20260424101900"},"Children":[{"ID":"20260424101900-e75alta","Type":"NodeParagraph","Properties":{"id":"20260424101900-e75alta","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"阶段之间的握手"}]}]},{"ID":"20260424101900-5q8un9b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-5q8un9b","updated":"20260424101900"},"Children":[{"ID":"20260424101900-sc7lo6a","Type":"NodeParagraph","Properties":{"id":"20260424101900-sc7lo6a","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"依赖与冒险"}]}]},{"ID":"20260424101900-hyqpxhh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-hyqpxhh","updated":"20260424101900"},"Children":[{"ID":"20260424101900-x65b73a","Type":"NodeParagraph","Properties":{"id":"20260424101900-x65b73a","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"资源冲突"}]}]},{"ID":"20260424101900-g83ryq4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-g83ryq4","updated":"20260424101900"},"Children":[{"ID":"20260424101900-7md7zct","Type":"NodeParagraph","Properties":{"id":"20260424101900-7md7zct","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"回压传播"}]}]}]},{"ID":"20260424101900-xz3b6vg","Type":"NodeParagraph","Properties":{"id":"20260424101900-xz3b6vg","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"真正的吞吐提升，很多时候来自“把等待重叠掉”，不是来自“多放一点算力”。"}]},{"ID":"20260424101900-pfkidta","Type":"NodeParagraph","Properties":{"id":"20260424101900-pfkidta","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"把几种常见 loop 变换压成硬件视角，可以更快判断它们为什么重要："}]},{"ID":"20260424101900-lei5ahb","Type":"NodeTable","TableAligns":[0,0,0,0],"Properties":{"colgroup":"|||","id":"20260424101900-lei5ahb","updated":"20260424101900"},"Children":[{"Type":"NodeTableHead","Data":"thead","Children":[{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"变换"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"直接改变什么"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"想换来的收益"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"常见副作用"}]}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Tiling"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"工作集大小与复用边界"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"数据留在片上更久"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"tile 太小会放大边界和 DMA 开销"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Unrolling"},{"Type":"NodeText","Data":"​"}]}