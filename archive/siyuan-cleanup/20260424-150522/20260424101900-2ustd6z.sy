dren":[{"ID":"20260424101900-06qnqkp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-06qnqkp","updated":"20260424101900"},"Children":[{"ID":"20260424101900-ujnm8h3","Type":"NodeParagraph","Properties":{"id":"20260424101900-ujnm8h3","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"修正：它经常决定了阵列能否以稳定节拍连续吃到正确形状的数据。"}]}]}]}]}]},{"ID":"20260424101900-pqx61j7","Type":"NodeParagraph","Properties":{"id":"20260424101900-pqx61j7","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"这一卷真正要建立的不是术语表，而是一种因果链："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"数据复用 -\u0026gt; loop/tile -\u0026gt; buffer 层级 -\u0026gt; DMA/预取 -\u0026gt; 实际吞吐"},{"Type":"NodeText","Data":"​。后面讲量化、稀疏和算子融合时，所有“省计算、省存储、省带宽”的收益，都要回到这条链上判断。"}]},{"ID":"20260424101900-f5mumci","Type":"NodeParagraph","Properties":{"id":"20260424101900-f5mumci","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"下一卷会沿着同一条链继续推进，但把重点从“怎么搬、怎么存、怎么排”切到“怎么用更少位宽、更少非零和更少中间结果，把这条链整体压缩下来”。"}]}]}