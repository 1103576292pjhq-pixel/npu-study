900-hjdsxef","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"归约维 K"},{"Type":"NodeText","Data":"​ 有多长"}]}]},{"ID":"20260424101900-kxreuy5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-kxreuy5","updated":"20260424101900"},"Children":[{"ID":"20260424101900-sb9458p","Type":"NodeParagraph","Properties":{"id":"20260424101900-sb9458p","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"输出空间"},{"Type":"NodeText","Data":"​ 有多大"}]}]},{"ID":"20260424101900-mztl3yu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-mztl3yu","updated":"20260424101900"},"Children":[{"ID":"20260424101900-2s4wi2q","Type":"NodeParagraph","Properties":{"id":"20260424101900-2s4wi2q","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"权重/激活/部分和"},{"Type":"NodeText","Data":"​ 各自复用多少次"}]}]}]},{"ID":"20260424101900-du2t78l","Type":"NodeParagraph","Properties":{"id":"20260424101900-du2t78l","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"例如卷积里，输入窗口和卷积核都可能被重复使用；而在 GEMM 里，A 和 B 的复用方式又不同。数据流设计要做的，就是把复用最高、搬运最贵的那部分数据尽量留在便宜层级。"}]},{"ID":"20260424101900-t0sxn34","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101900-t0sxn34","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"3. 数据流不是抽象概念，而是循环嵌套的物理化"}]},{"ID":"20260424101900-q92tu63","Type":"NodeParagraph","Properties":{"id":"20260424101900-q92tu63","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"软件里一个卷积常被写成多重循环："}]},{"ID":"20260424101900-8j4wa98","Type":"NodeParagraph","Properties":{"id":"20260424101900-8j4wa98","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"for n, oc, oh, ow, ic, kh, kw"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101900-416zqbo","Type":"NodeParagraph","Properties":{"id":"20260424101900-416zqbo","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"硬件不会真的按“软件循环”逐条解释执行，而会把它变成："}]},{"ID":"20260424101900-2272o3o","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-2272o3o","updated":"20260424101900"},"Children":[{"ID":"20260424101900-sxcoseo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-sxcoseo","updated":"20260424101900"},"Children":[{"ID":"20260424101900-9a7tj67","Type":"NodeParagraph","Properties":{"id":"20260424101900-9a7tj67","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"哪些循环映射到空间并行"}]}]},{"ID":"20260424101900-nhgbb0g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-nhgbb0g","updated":"20260424101900"},"Children":[{"ID":"20260424101900-npelar6","Type":"NodeParagraph","Properties":{"id":"20260424101900-npelar6","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"哪些循环映射到时间展开"}]}]},{"ID":"20260424101900-awz3694","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-awz3694","updated":"20260424101900"},"Children":[{"ID":"20260424101900-qg5koio","Type":"NodeParagraph","Properties":{"id":"20260424101900-qg5koio","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"哪些循环变成 tile"}]}]},{"ID":"20260424101900-ajzy3hh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-ajzy3hh","updated":"20260424101900"},"Children":[{"ID":"20260424101900-nt0iu88","Type":"NodeParagraph","Properties":{"id":"20260424101900-nt0iu88","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"哪些循环由 DMA 负责供数"}]}]}]},{"ID":"20260424101900-elygvd8","Type":"NodeParagraph","Properties":{"id":"20260424101900-elygvd8","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"所以一个数据流方案，本质上就是在回答："}]},{"ID":"20260424101900-di31m09","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-di31m09","updated":"20260424101900"},"Children":[{"ID":"20260424101900-c5b6tkv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-c5b6tkv","updated":"20260424101900"},"Children":[{"ID":"20260424101900-g0a3slq","Type":"NodeParagraph","Properties":{"id":"20260424101900-g0a3slq","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"空间映射"},{"Type":"NodeText","Data":"​：哪个维度铺到阵列"}]}]},{"ID":"20260424101900-9fu5b7o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-9fu5b7o","updated":"20260424101900"},"Children":[{"ID":"20260424101900-edd3zkv","Type":"NodeParagraph","Properties":{"id":"20260424101900-edd3zkv","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"时间映射"},{"Type":"NodeText","Data":"​：哪个维度按批次推进"}]}]},{"ID":"20260424101900-47qnvgz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-47qnvgz","updated":"20260424101900"},"Children":[{"ID":"20260424101900-e6rg83i","Type":"NodeParagraph","Properties":{"id":"20260424101900-e6rg83i","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"存储映射"},{"Type":"NodeText","Data":"​：哪一级 buffer 保存哪一类 tile"}]}]}]},{"ID":"20260424101900-gt0skx8","Type":"NodeParagraph","Properties":{"id":"20260424101900-gt0skx8","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"把这三件事一起固定下来，循环嵌套就不再是抽象程序结构，而是物理执行节奏。"}]},{"ID":"20260424101900-pskfori","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101900-pskfori","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"4. 硬件循环的作用：把规则重复工作交给专用控制"}]},{"ID":"20260424101900-xmhg8uk","Type":"NodeParagraph","Properties":{"id":"20260424101900-xmhg8uk","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"如果每处理一个 tile、每做一次小块归约，都要由通用控制器重新取指、解码、分支，那么阵列很难保持高利用率。硬件循环的价值就是把这种"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"高度规则、反复出现的循环结构"},{"Type":"NodeText","Data":"​沉到专用控制逻辑里。"}]},{"ID":"20260424101900-3n6cunc","Type":"NodeParagraph","Properties":{"id":"20260424101900-3n6cunc","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"一个典型硬件循环单元会负责："}]},{"ID":"20260424101900-t3o1dsu","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101900-t3o1dsu","updated":"20260424101900"},"Children":[{"ID":"20260424101900-gsetb6j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-gsetb6j","updated":"20260424101900"},"Children":[{"ID":"20260424101900-6iy4ver","Type":"NodeParagraph","Properties":{"id":"20260424101900-6iy4ver","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"计数器更新"}]}]},{"ID":"20260424101900-d0vzvjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-d0vzvjs","updated":"20260424101900"},"Children":[{"ID":"20260424101900-wwvdge7","Type":"NodeParagraph","Properties":{"id":"20260424101900-wwvdge7","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"loop bound 判断"}]}]},{"ID":"20260424101900-gomrr55","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-gomrr55","updated":"20260424101900"},"Children":[{"ID":"20260424101900-diqmqkm","Type":"NodeParagraph","Properties":{"id":"20260424101900-diqmqkm","updated":"20260424101900"},"Children":[{"Type":"NodeText","Data":"地址生成"}]}]},{"ID":"20260424101900-6l5p8z5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101900-6l5p8z5","upda