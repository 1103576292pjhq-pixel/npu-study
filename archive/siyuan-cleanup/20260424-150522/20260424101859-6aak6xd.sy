0ay","updated":"20260424101859"},"Children":[{"ID":"20260424101859-krnpl9z","Type":"NodeParagraph","Properties":{"id":"20260424101859-krnpl9z","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"卷积"},{"Type":"NodeText","Data":"​：滑动窗口上的乘加与归约"}]}]},{"ID":"20260424101859-3dcn08h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-3dcn08h","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ir68il9","Type":"NodeParagraph","Properties":{"id":"20260424101859-ir68il9","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"GEMM"},{"Type":"NodeText","Data":"​：规则矩阵乘加"}]}]},{"ID":"20260424101859-xwsokh2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-xwsokh2","updated":"20260424101859"},"Children":[{"ID":"20260424101859-llf1vio","Type":"NodeParagraph","Properties":{"id":"20260424101859-llf1vio","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"Attention"},{"Type":"NodeText","Data":"​：矩阵乘、缩放、softmax、再乘一次 value"}]}]},{"ID":"20260424101859-mrletaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-mrletaw","updated":"20260424101859"},"Children":[{"ID":"20260424101859-zneirwj","Type":"NodeParagraph","Properties":{"id":"20260424101859-zneirwj","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"MLP"},{"Type":"NodeText","Data":"​：大矩阵乘 + 非线性"}]}]}]},{"ID":"20260424101859-gf975du","Type":"NodeParagraph","Properties":{"id":"20260424101859-gf975du","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"这意味着一大类 AI 负载最后都会被翻译成“很多次乘加 + 若干次非线性 + 大量中间张量搬运”。"}]},{"ID":"20260424101859-tyesnme","Type":"NodeParagraph","Properties":{"id":"20260424101859-tyesnme","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"在真正进入硬件之前，先把几个最容易混用的词压到同一张表里："}]},{"ID":"20260424101859-9rz1kyh","Type":"NodeTable","TableAligns":[0,0,0],"Properties":{"colgroup":"||","id":"20260424101859-9rz1kyh","updated":"20260424101859"},"Children":[{"Type":"NodeTableHead","Data":"thead","Children":[{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"词"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"在这里真正指什么"}]},{"Type":"NodeTableCell","Data":"th","Children":[{"Type":"NodeText","Data":"常见误解"}]}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"shape"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"张量每个维度的大小"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"只看总元素数，不看维度顺序"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"layout"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"张量在内存里的排布方式，如 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"NCHW"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"NHWC"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"觉得只是软件表示，不影响硬件搬运"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"operator"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"一种有输入、输出和依赖关系的变换"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"把模型名直接当成硬件操作"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"reduction"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"多个乘积或中间值归并到一个结果的过程"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"只看到乘法，不看到累加与部分和"}]}]},{"Type":"NodeTableRow","Data":"tr","Children":[{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"tile"},{"Type":"NodeText","Data":"​"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"为了片上复用而切出来的一小块计算/数据工作集"}]},{"Type":"NodeTableCell","Data":"td","Children":[{"Type":"NodeText","Data":"误以为只是“把大矩阵拆小”"}]}]}]},{"ID":"20260424101859-e4pi02f","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-e4pi02f","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"2. 为什么 NPU 讨论里总绕不开矩阵乘加"}]},{"ID":"20260424101859-u3ruzhh","Type":"NodeParagraph","Properties":{"id":"20260424101859-u3ruzhh","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"不是因为 AI 只有乘加，而是因为乘加通常占据了绝大多数算量，而且最适合专用阵列化。"}]},{"ID":"20260424101859-zp3kohb","Type":"NodeParagraph","Properties":{"id":"20260424101859-zp3kohb","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"把一个最普通的矩阵乘写出来："}]},{"ID":"20260424101859-4uom6mn","Type":"NodeParagraph","Properties":{"id":"20260424101859-4uom6mn","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"C[m,n] = Σ_k A[m,k] * B[k,n]"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-44ab2vd","Type":"NodeParagraph","Properties":{"id":"20260424101859-44ab2vd","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"它天然暴露了 NPU 设计最关心的三个维度："}]},{"ID":"20260424101859-q853fh4","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-q853fh4","updated":"20260424101859"},"Children":[{"ID":"20260424101859-3ntrs6k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-3ntrs6k","updated":"20260424101859"},"Children":[{"ID":"20260424101859-p7smfha","Type":"NodeParagraph","Properties":{"id":"20260424101859-p7smfha","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"并行度"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-0vrucja","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-0vrucja","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ifq6054","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-ifq6054","updated":"20260424101859"},"Children":[{"ID":"20260424101859-zor497h","Type":"NodeParagraph","Properties":{"id":"20260424101859-zor497h","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"不同的 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"m"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"n"},{"Type":"NodeText","Data":"​ 可以同时算。"}]}]}]}]},{"ID":"20260424101859-r2l4n5s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-r2l4n5s","updated":"20260424101859"},"Children":[{"ID":"20260424101859-a70f4pm","Type":"NodeParagraph","Properties":{"id":"20260424101859-a70f4pm","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"归约维"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-k0a43en","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-k0a43en","updated":"20260424101859"},"Children":[{"ID":"20260424101859-9s4b2wo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-9s4b2wo","updated":"20260424101859"},"Children":[{"ID":"20260424101859-tcm6fnj","Type":"NodeParagraph","Properties":{"id":"20260424101859-tcm6fnj","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"k"},{"Type":"NodeText","Data":"​ 是不断累加的维度，决定部分和的保存方式。"}]}]}]}]},{"ID":"20260424101859-ya1l3bo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-ya1l3bo","updated":"20260424101859"},"Children":[{"ID":"20260424101859-2n1e19i","Type":"NodeParagraph","Properties":{"id":"20260424101859-2n1e19i","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"复用机会"},{"Type":"NodeText","Data":"​"}]},{"ID":"20260424101859-a2uzizc","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-a2uzizc","updated":"20260424101859"},"Children":[{"ID":"20260424101859-4ckvm0i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-4ckvm0i","updated":"20260424101859"},"Children":[{"ID":"20260424101859-ipourwq","Type":"NodeParagraph","Properties":{"id":"20260424101859-ipourwq","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"A"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"B"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"C"},{"Type":"NodeText","Data":"​ 三类数据到底谁应该留在本地，谁应该流动。"}]}]}]}]}]},{"ID":"20260424101859-q4gkktg","Type":"NodeParagraph","Properties":{"id":"20260424101859-q4gkktg","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"卷积只是把这个骨架换了一个索引表达。真正做硬件时，经常会把卷积映射为 GEMM，或者至少按 GEMM 的思路分析它的复用和带宽压力。"}]},{"ID":"20260424101859-uld6k3d","Type":"NodeParagraph","Properties":{"id":"20260424101859-uld6k3d","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"所以 NPU 不是“会跑神经网络的黑箱”，而是“围绕乘加与归约，尽量减少无效搬运的专用机器”。"}]},{"ID":"20260424101859-qsx3cfx","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260424101859-qsx3cfx","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"3. 计算不一定贵，搬运通常更贵"}]},{"ID":"20260424101859-f1no1h9","Type":"NodeParagraph","Properties":{"id":"20260424101859-f1no1h9","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"初学 NPU 最容易犯的错，是只盯着算力数量，不盯着数据从哪里来、往哪里去。"}]},{"ID":"20260424101859-n15zspt","Type":"NodeParagraph","Properties":{"id":"20260424101859-n15zspt","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"原因很简单："}]},{"ID":"20260424101859-e3agerb","Type":"NodeList","ListData":{},"Properties":{"id":"20260424101859-e3agerb","updated":"20260424101859"},"Children":[{"ID":"20260424101859-rwmtxr8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-rwmtxr8","updated":"20260424101859"},"Children":[{"ID":"20260424101859-wopazqt","Type":"NodeParagraph","Properties":{"id":"20260424101859-wopazqt","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"一次 MAC 的逻辑不复杂，容易大规模复制。"}]}]},{"ID":"20260424101859-tvp4g4s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-tvp4g4s","updated":"20260424101859"},"Children":[{"ID":"20260424101859-6hfljaw","Type":"NodeParagraph","Properties":{"id":"20260424101859-6hfljaw","updated":"20260424101859"},"Children":[{"Type":"NodeText","Data":"数据一旦离开寄存器文件和局部 SRAM，走到更远层级，单位能量和延迟都会迅速变差。"}]}]},{"ID":"20260424101859-1jcoaxf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260424101859-1jcoaxf","updated":"2026042410185