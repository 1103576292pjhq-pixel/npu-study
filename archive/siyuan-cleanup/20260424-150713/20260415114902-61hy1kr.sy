15115116"},"Children":[{"Type":"NodeText","Data":"系统级帮你建立大局观"}]}]},{"ID":"20260415115116-yzhdu2f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-yzhdu2f","updated":"20260415115116"},"Children":[{"ID":"20260415115116-fiiwmag","Type":"NodeParagraph","Properties":{"id":"20260415115116-fiiwmag","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"算法级帮你理解功能"}]}]},{"ID":"20260415115116-na568m3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-na568m3","updated":"20260415115116"},"Children":[{"ID":"20260415115116-1u0m9qq","Type":"NodeParagraph","Properties":{"id":"20260415115116-1u0m9qq","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"门级帮你理解底层结构"}]}]}]},{"ID":"20260415115116-r1bhokf","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-r1bhokf","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"暂时知道即可"}]},{"ID":"20260415115116-cvfo6lr","Type":"NodeParagraph","Properties":{"id":"20260415115116-cvfo6lr","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"开关级"}]},{"ID":"20260415115116-g8c2ovm","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-g8c2ovm","updated":"20260415115116"}},{"ID":"20260415115116-ll1a1ro","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-ll1a1ro","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"9. “行为描述”和“结构描述”是什么关系"}]},{"ID":"20260415115116-zsbduyc","Type":"NodeParagraph","Properties":{"id":"20260415115116-zsbduyc","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"原书非常明确地说："}]},{"ID":"20260415115116-xc10a98","Type":"NodeParagraph","Properties":{"id":"20260415115116-xc10a98","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Verilog 既是行为描述语言，也是结构描述语言。"}]},{"ID":"20260415115116-1f81km1","Type":"NodeParagraph","Properties":{"id":"20260415115116-1f81km1","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这句话特别重要。"}]},{"ID":"20260415115116-whv4ya5","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-whv4ya5","updated":"20260415115116"}},{"ID":"20260415115116-ms86gsd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-ms86gsd","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"10. 结构描述：像“搭积木”"}]},{"ID":"20260415115116-no4gokn","Type":"NodeParagraph","Properties":{"id":"20260415115116-no4gokn","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"结构描述，就是你明确写出："}]},{"ID":"20260415115116-mekty2v","Type":"NodeList","ListData":{},"Properties":{"id":"20260415115116-mekty2v","updated":"20260415115116"},"Children":[{"ID":"20260415115116-x82msq2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-x82msq2","updated":"20260415115116"},"Children":[{"ID":"20260415115116-s4u8w63","Type":"NodeParagraph","Properties":{"id":"20260415115116-s4u8w63","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"用了哪些模块"}]}]},{"ID":"20260415115116-nd9jic0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-nd9jic0","updated":"20260415115116"},"Children":[{"ID":"20260415115116-yuedicv","Type":"NodeParagraph","Properties":{"id":"20260415115116-yuedicv","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"模块之间怎么连"}]}]},{"ID":"20260415115116-33v4hp0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-33v4hp0","updated":"20260415115116"},"Children":[{"ID":"20260415115116-4pezeas","Type":"NodeParagraph","Properties":{"id":"20260415115116-4pezeas","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"或者用了哪些门"}]}]},{"ID":"20260415115116-unpo3kr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-unpo3kr","updated":"20260415115116"},"Children":[{"ID":"20260415115116-1ivjyzq","Type":"NodeParagraph","Properties":{"id":"20260415115116-1ivjyzq","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"门之间怎么连"}]}]}]},{"ID":"20260415115116-voen2wd","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-voen2wd","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"例子：2 选 1 多路器的结构写法"}]},{"ID":"20260415115116-0h4wu2q","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20260415115116-0h4wu2q","updated":"20260415115116"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dmVyaWxvZw=="},{"Type":"NodeCodeBlockCode","Data":"module mux2_struct (\n    input  wire a,\n    input  wire b,\n    input  wire sel,\n    output wire y\n);\n\nwire sel_n;\nwire y1, y2;\n\nnot u1(sel_n, sel);\nand u2(y1, a, sel_n);\nand u3(y2, b, sel);\nor  u4(y, y1, y2);\n\nendmodule\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20260415115116-tx4xwvg","Type":"NodeParagraph","Properties":{"id":"20260415115116-tx4xwvg","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这个写法的意思不是“选择功能是什么”，而是："}]},{"ID":"20260415115116-k1nzpcu","Type":"NodeParagraph","Properties":{"id":"20260415115116-k1nzpcu","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"这个功能由哪些门搭出来。"}]},{"ID":"20260415115116-fcsldo1","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-fcsldo1","updated":"20260415115116"}},{"ID":"20260415115116-sq95aft","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-sq95aft","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"11. 行为描述：像“说规则”"}]},{"ID":"20260415115116-4h50y86","Type":"NodeParagraph","Properties":{"id":"20260415115116-4h50y86","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"行为描述，就是你用 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"always"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"if"},{"Type":"NodeText","Data":"​、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"case"},{"Type":"NodeText","Data":"​ 这些过程语句，描述："}]},{"ID":"20260415115116-necbc9u","Type":"NodeParagraph","Properties":{"id":"20260415115116-necbc9u","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输入变化时，输出应该怎样变化。"}]},{"ID":"20260415115116-t5feegw","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-t5feegw","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"例子：同一个 2 选 1 多路器的行为写法"}]},{"ID":"20260415115116-qd3qnvc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20260415115116-qd3qnvc","updated":"20260415115116"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dmVyaWxvZw=="},{"Type":"NodeCodeBlockCode","Data":"module mux2_behav (\n    input  wire a,\n    input  wire b,\n    input  wire sel,\n    output reg  y\n);\n\nalways @(*) begin\n    if (sel)\n        y = b;\n    else\n        y = a;\nend\n\nendmodule\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20260415115116-7iy8jvv","Type":"NodeParagraph","Properties":{"id":"20260415115116-7iy8jvv","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这个写法没有直接写 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"and/or/not"},{"Type":"NodeText","Data":"​，但功能一样。"}]},{"ID":"20260415115116-4ud578r","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-4ud578r","updated":"20260415115116"}},{"ID":"20260415115116-fh1yf1k","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-fh1yf1k","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"12. 同一个功能，可以有不同层次、不同风格"}]},{"ID":"20260415115116-7jbwf5m","Type":"NodeParagraph","Properties":{"id":"20260415115116-7jbwf5m","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你现在一定要建立一个观念："}]},{"ID":"20260415115116-3do1nug","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-3do1nug","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“功能相同”不等于“写法相同”"}]},{"ID":"20260415115116-sykb96w","Type":"NodeParagraph","Properties":{"id":"20260415115116-sykb96w","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"比如同一个寄存器："}]},{"ID":"20260415115116-m472yr1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-m472yr1","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"RTL 写法"}]},{"ID":"20260415115116-9qxl9mv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20260415115116-9qxl9mv","updated":"20260415115116"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dmVyaWxvZw=="},{"Type":"NodeCodeBlockCode","Data":"always @(posedge clk or negedge rst_n) begin\n    if (!rst_n)\n        q \u003c= 1'b0;\n    else\n        q \u003c= d;\nend\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20260415115116-b5l119u","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-b5l119u","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"门级 / 底层结构写法"}]},{"ID":"20260415115116-8fn8rey","Type":"NodeParagraph","Properties":{"id":"20260415115116-8fn8rey","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"可以写成 D 触发器实例调用，甚至更底层用门搭。"}]},{"ID":"20260415115116-apk6cl9","Type":"NodeParagraph","Properties":{"id":"20260415115116-apk6cl9","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这就是“同一电路，多种抽象”。"}]},{"ID":"20260415115116-fm482l5","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-fm482l5","updated":"20260415115116"}},{"ID":"20260415115116-l5xhshd","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-l5xhshd","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"13. 一个复杂工程里，通常不是只用一种层次"}]},{"ID":"20260415115116-3f7e4oa","Type":"NodeParagraph","Properties":{"id":"20260415115116-3f7e4oa","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"原书强调，一个复杂系统的完整 Verilog 模型，是由多个模块和子模块构成的，其中有些模块是需要综合的，有些只是激励源或外部环境。"}]},{"ID":"20260415115116-oroxrs7","Type":"NodeParagraph","Properties":{"id":"20260415115116-oroxrs7","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"也就是说，真正工程里常常是这样："}]},{"ID":"20260415115116-8tz1x43","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-8tz1x43","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"顶层"}]},{"ID":"20260415115116-ol2d8vu","Type":"NodeParagraph","Properties":{"id":"20260415115116-ol2d8vu","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"系统级 / 结构级"}]},{"ID":"20260415115116-gdkotpr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-gdkotpr","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"核心功能模块"}]},{"ID":"20260415115116-8g0eed5","Type":"NodeParagraph","Properties":{"id":"20260415115116-8g0eed5","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"RTL 级"}]},{"ID":"20260415115116-e4gnsto","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-e4gnsto","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"某些参考模型"}]},{"ID":"20260415115116-nxuhksz","Type":"NodeParagraph","Properties":{"id":"20260415115116-nxuhksz","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"算法级 / 行为级"}]},{"ID":"20260415115116-dfnjgfg","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-dfnjgfg","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"测试平台"}]},{"ID":"20260415115116-uj3jqix","Type":"NodeParagraph","Properties":{"id":"20260415115116-uj3jqix","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"行为级，不综合"}]},{"ID":"20260415115116-mi2qw6f","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-mi2qw6f","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"底层库"}]},{"ID":"20260415115116-hlsg5e6","Type":"NodeParagraph","Properties":{"id":"20260415115116-hlsg5e6","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"门级 / UDP / 更低层模型"}]},{"ID":"20260415115116-3gjuo3w","Type":"NodeParagraph","Properties":{"id":"20260415115116-3gjuo3w","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"所以不是说“只能选一种写法”，而是："}]},{"ID":"20260415115116-dg21gwn","Type":"NodeParagraph","Properties":{"id":"20260415115116-dg21gwn","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"每一层用最适合它的写法。"}]},{"ID":"20260415115116-a09c2ci","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-a09c2ci","updated":"20260415115116"}},{"ID":"20260415115116-b5yfh1h","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-b5yfh1h","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"14. 为什么学这个很重要"}]},{"ID":"20260415115116-uryro7r","Type":"NodeParagraph","Properties":{"id":"20260415115116-uryro7r","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"因为你后面会越来越经常遇到这几种情况："}]},{"ID":"20260415115116-ptmze2e","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-ptmze2e","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"情况 1"}]},{"ID":"20260415115116-4hnasya","Type":"NodeParagraph","Properties":{"id":"20260415115116-4hnasya","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你能看懂一个模块功能，但看不懂它属于哪个抽象层次。\n于是你会误以为“所有 Verilog 都差不多”。"}]},{"ID":"20260415115116-ld1k62d","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-ld1k62d","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"情况 2"}]},{"ID":"20260415115116-34qudo8","Type":"NodeParagraph","Properties":{"id":"20260415115116-34qudo8","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你拿行为模型直接想综合，结果发现有些写法不适合综合。"}]},{"ID":"20260415115116-je5vsck","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-je5vsck","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"情况 3"}]},{"ID":"20260415115116-yb8jc7e","Type":"NodeParagraph","Properties":{"id":"20260415115116-yb8jc7e","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你明明写的是 RTL，却在脑子里按 C 语言顺序程序理解，结果时序思维混乱。"}]},{"ID":"20260415115116-ftzqmyf","Type":"NodeParagraph","Properties":{"id":"20260415115116-ftzqmyf","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"所以这一课的目的就是让你先分清："}]},{"ID":"20260415115116-z22ahf4","Type":"NodeParagraph","Properties":{"id":"20260415115116-z22ahf4","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"我现在写的，到底是在描述功能、结构，还是寄存器间的数据流。"}]},{"ID":"20260415115116-me7ydsv","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-me7ydsv","updated":"20260415115116"}},{"ID":"20260415115116-904z2ii","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-904z2ii","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"15. 这一课你先记住的结论"}]},{"ID":"20260415115116-bf59jid","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-bf59jid","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"第一条"}]},{"ID":"20260415115116-zppf4b2","Type":"NodeParagraph","Properties":{"id":"20260415115116-zppf4b2","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"Verilog 可以描述硬件的不同抽象层次。\n原书列出五种："},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"系统级、算法级、RTL 级、门级、开关级。"}]},{"ID":"20260415115116-8u37vt9","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-8u37vt9","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"第二条"}]},{"ID":"20260415115116-z6sio1v","Type":"NodeParagraph","Properties":{"id":"20260415115116-z6sio1v","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"对你现在最重要的是 ​"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"RTL 级"},{"Type":"NodeText","Data":"​。"}]},{"ID":"20260415115116-dsj78dr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-dsj78dr","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"第三条"}]},{"ID":"20260415115116-cv0ak1y","Type":"NodeParagraph","Properties":{"id":"20260415115116-cv0ak1y","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"Verilog 既能做​"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"行为描述"},{"Type":"NodeText","Data":"​，也能做​"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"结构描述"},{"Type":"NodeText","Data":"​。"}]},{"ID":"20260415115116-h46vz73","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-h46vz73","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"第四条"}]},{"ID":"20260415115116-1m2xdb0","Type":"NodeParagraph","Properties":{"id":"20260415115116-1m2xdb0","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"一个复杂工程通常会混合使用多种层次和多种风格。"}]},{"ID":"20260415115116-oe0o1zv","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-oe0o1zv","updated":"20260415115116"}},{"ID":"20260415115116-98431fx","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260415115116-98431fx","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"本课小练习"}]},{"ID":"20260415115116-m44bnbb","Type":"NodeParagraph","Properties":{"id":"20260415115116-m44bnbb","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"先别急着看答案，你先自己想。"}]},{"ID":"20260415115116-tejnfi7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-tejnfi7","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 1"}]},{"ID":"20260415115116-m2mhxv0","Type":"NodeParagraph","Properties":{"id":"20260415115116-m2mhxv0","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"下面这句话更接近哪一层？"}]},{"ID":"20260415115116-1yf3k0l","Type":"NodeParagraph","Properties":{"id":"20260415115116-1yf3k0l","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“模块每个时钟上升沿，把输入数据送入寄存器 q。”"}]},{"ID":"20260415115116-q2g4ftp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-q2g4ftp","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 2"}]},{"ID":"20260415115116-4i45al2","Type":"NodeParagraph","Properties":{"id":"20260415115116-4i45al2","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"下面这句话更接近哪一层？"}]},{"ID":"20260415115116-ts3uiir","Type":"NodeParagraph","Properties":{"id":"20260415115116-ts3uiir","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“输出 y 由两个与门、一个或门、一个非门连接而成。”"}]},{"ID":"20260415115116-rcecmi5","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-rcecmi5","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 3"}]},{"ID":"20260415115116-pef6n3q","Type":"NodeParagraph","Properties":{"id":"20260415115116-pef6n3q","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"下面这句话更接近哪一层？"}]},{"ID":"20260415115116-uny6i7d","Type":"NodeParagraph","Properties":{"id":"20260415115116-uny6i7d","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“整个系统分为控制器、数据通路、存储器接口三大部分。”"}]},{"ID":"20260415115116-vmtixnt","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-vmtixnt","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 4"}]},{"ID":"20260415115116-m99wkxm","Type":"NodeParagraph","Properties":{"id":"20260415115116-m99wkxm","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"always @(posedge clk)"},{"Type":"NodeText","Data":"​ 这种写法最常见于哪一层？"}]},{"ID":"20260415115116-ortwefl","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-ortwefl","updated":"20260415115116"}},{"ID":"20260415115116-gexd3pr","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260415115116-gexd3pr","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"参考答案"}]},{"ID":"20260415115116-hq4sqls","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-hq4sqls","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 1 答案"}]},{"ID":"20260415115116-z7laluq","Type":"NodeParagraph","Properties":{"id":"20260415115116-z7laluq","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"RTL 级"}]},{"ID":"20260415115116-hgo162n","Type":"NodeParagraph","Properties":{"id":"20260415115116-hgo162n","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"因为它说的是：在时钟沿，数据进入寄存器。\n这正是“寄存器之间的数据传输”。"}]},{"ID":"20260415115116-htcau6p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-htcau6p","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 2 答案"}]},{"ID":"20260415115116-p76eym9","Type":"NodeParagraph","Properties":{"id":"20260415115116-p76eym9","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"门级 / 结构描述"}]},{"ID":"20260415115116-hg7wwb6","Type":"NodeParagraph","Properties":{"id":"20260415115116-hg7wwb6","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"因为它明确说了用了哪些门、怎么连接。"}]},{"ID":"20260415115116-wazr320","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-wazr320","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 3 答案"}]},{"ID":"20260415115116-4hiwivw","Type":"NodeParagraph","Properties":{"id":"20260415115116-4hiwivw","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"系统级"}]},{"ID":"20260415115116-xd5ryiv","Type":"NodeParagraph","Properties":{"id":"20260415115116-xd5ryiv","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"因为它在讲系统分块，而不是具体寄存器和门。"}]},{"ID":"20260415115116-ovoj0vr","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-ovoj0vr","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"题 4 答案"}]},{"ID":"20260415115116-c78ntb2","Type":"NodeParagraph","Properties":{"id":"20260415115116-c78ntb2","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"RTL 级"}]},{"ID":"20260415115116-0dhv44k","Type":"NodeParagraph","Properties":{"id":"20260415115116-0dhv44k","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"因为它通常用来描述时钟驱动的寄存器更新。"}]},{"ID":"20260415115116-9vefewc","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-9vefewc","updated":"20260415115116"}},{"ID":"20260415115116-g0uuhx1","Type":"NodeParagraph","Properties":{"id":"20260415115116-g0uuhx1","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"下一课我接着讲："}]},{"ID":"20260415115116-r3wqj7q","Type":"NodeParagraph","Properties":{"id":"20260415115116-r3wqj7q","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"第五阶段 第 2 课：结构化建模和行为建模，到底怎么区分，怎么选。"}]}]}