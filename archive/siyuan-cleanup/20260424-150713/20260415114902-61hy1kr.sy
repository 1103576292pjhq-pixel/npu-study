"}]},{"ID":"20260415115116-7slmao2","Type":"NodeParagraph","Properties":{"id":"20260415115116-7slmao2","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“站在系统总设计师视角看这个模块。”"}]},{"ID":"20260415115116-ca8ao4c","Type":"NodeParagraph","Properties":{"id":"20260415115116-ca8ao4c","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"比如一个 CPU 顶层，先分成："}]},{"ID":"20260415115116-5wvu1oe","Type":"NodeList","ListData":{},"Properties":{"id":"20260415115116-5wvu1oe","updated":"20260415115116"},"Children":[{"ID":"20260415115116-lmc6dih","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-lmc6dih","updated":"20260415115116"},"Children":[{"ID":"20260415115116-5sd7d8u","Type":"NodeParagraph","Properties":{"id":"20260415115116-5sd7d8u","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"PC"}]}]},{"ID":"20260415115116-aitsi88","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-aitsi88","updated":"20260415115116"},"Children":[{"ID":"20260415115116-08tyjlm","Type":"NodeParagraph","Properties":{"id":"20260415115116-08tyjlm","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"指令寄存器"}]}]},{"ID":"20260415115116-x5zejae","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-x5zejae","updated":"20260415115116"},"Children":[{"ID":"20260415115116-i55fvlk","Type":"NodeParagraph","Properties":{"id":"20260415115116-i55fvlk","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"ALU"}]}]},{"ID":"20260415115116-e40z8dn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-e40z8dn","updated":"20260415115116"},"Children":[{"ID":"20260415115116-ks13oyq","Type":"NodeParagraph","Properties":{"id":"20260415115116-ks13oyq","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"控制器"}]}]},{"ID":"20260415115116-qev42qh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-qev42qh","updated":"20260415115116"},"Children":[{"ID":"20260415115116-b9nrm83","Type":"NodeParagraph","Properties":{"id":"20260415115116-b9nrm83","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"RAM 接口"}]}]}]},{"ID":"20260415115116-2gdpivh","Type":"NodeParagraph","Properties":{"id":"20260415115116-2gdpivh","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这个时候，重点是：\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"先把系统分块、接口理顺、数据流方向理顺。"}]},{"ID":"20260415115116-5eso8xd","Type":"NodeParagraph","Properties":{"id":"20260415115116-5eso8xd","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"原书也强调，复杂系统可以先通过高层模块把系统分解成若干可操作模块，再通过仿真验证模块关系是否合理，这正是 Top-Down 设计的重要作用。"}]},{"ID":"20260415115116-5ooflw3","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-5ooflw3","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"特点"}]},{"ID":"20260415115116-6g4v1ut","Type":"NodeParagraph","Properties":{"id":"20260415115116-6g4v1ut","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"系统级最像“设计蓝图”。"}]},{"ID":"20260415115116-cuevbu1","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-cuevbu1","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"例子"}]},{"ID":"20260415115116-hi1r8p7","Type":"NodeParagraph","Properties":{"id":"20260415115116-hi1r8p7","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你先不写 ALU 细节，只写："}]},{"ID":"20260415115116-njqtnn5","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20260415115116-njqtnn5","updated":"20260415115116"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dmVyaWxvZw=="},{"Type":"NodeCodeBlockCode","Data":"module cpu_top (\n    input  wire clk,\n    input  wire rst_n,\n    output wire [7:0] out\n);\n\nwire [7:0] alu_result;\nwire [7:0] reg_data;\n\npc      u_pc (...);\nir      u_ir (...);\nalu     u_alu(...);\ncontrol u_ctrl(...);\n\nassign out = alu_result;\n\nendmodule\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20260415115116-dkla212","Type":"NodeParagraph","Properties":{"id":"20260415115116-dkla212","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这里你重点不是 ALU 内部怎么加，而是："}]},{"ID":"20260415115116-94at6xj","Type":"NodeParagraph","Properties":{"id":"20260415115116-94at6xj","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"CPU 由哪些大块组成，块和块怎么连。"}]},{"ID":"20260415115116-a5q0pi7","Type":"NodeThematicBreak","Properties":{"id":"20260415115116-a5q0pi7","updated":"20260415115116"}},{"ID":"20260415115116-5cazg5a","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260415115116-5cazg5a","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"4. 算法级（Algorithmic Level）"}]},{"ID":"20260415115116-ioj7e4e","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-ioj7e4e","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"它在描述什么"}]},{"ID":"20260415115116-d3ke0tz","Type":"NodeParagraph","Properties":{"id":"20260415115116-d3ke0tz","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"它描述的是："}]},{"ID":"20260415115116-wyy42sw","Type":"NodeParagraph","Properties":{"id":"20260415115116-wyy42sw","updated":"20260415115116"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"这个功能按照什么算法完成。"}]},{"ID":"20260415115116-8hznlan","Type":"NodeParagraph","Properties":{"id":"20260415115116-8hznlan","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"书里说，算法级是“用高级语言结构实现设计算法的模型”。"}]},{"ID":"20260415115116-zxfb8p4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-zxfb8p4","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"你可以把它理解成"}]},{"ID":"20260415115116-k07d6d2","Type":"NodeParagraph","Properties":{"id":"20260415115116-k07d6d2","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"“我先把运算思路写出来。”"}]},{"ID":"20260415115116-00yyfqh","Type":"NodeParagraph","Properties":{"id":"20260415115116-00yyfqh","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"比如："}]},{"ID":"20260415115116-jder5b4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"Properties":{"id":"20260415115116-jder5b4","updated":"20260415115116"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```"},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dmVyaWxvZw=="},{"Type":"NodeCodeBlockCode","Data":"always @(*) begin\n    result = (a * b) + c;\nend\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```"}]},{"ID":"20260415115116-jv6zhvh","Type":"NodeParagraph","Properties":{"id":"20260415115116-jv6zhvh","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"这时候你说的是运算关系，不是在说内部用几个乘法器、几个加法器、要不要流水线。"}]},{"ID":"20260415115116-b1d7vzz","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-b1d7vzz","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"特点"}]},{"ID":"20260415115116-8s50hct","Type":"NodeParagraph","Properties":{"id":"20260415115116-8s50hct","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"它离“数学公式”很近，离“具体电路结构”还稍微远一点。"}]},{"ID":"20260415115116-5f6z7qj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260415115116-5f6z7qj","updated":"20260415115116"},"Children":[{"Type":"NodeText","Data":"典型场景"}]},{"ID":"20260415115116-8hp22e9","Type":"NodeList","ListData":{},"Properties":{"id":"20260415115116-8hp22e9","updated":"20260415115116"},"Children":[{"ID":"20260415115116-yubs4f1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260415115116-yubs4f1","updated":"20260415115116"},"Children":[{"ID":"20260415115116-lnhus8b","Type":"NodeParagraph","Properties":{"id":"20260415115116-lnhus8b","updated":"20260415115116"},"Ch